<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F1EA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->

        <include
            android:id="@+id/headerCommon"
            layout="@layout/header_layoutcommon" />

        <!-- PROFILE SECTION -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="220dp"
                        android:layout_height="220dp"
                        android:background="@drawable/circle_bg"
                        android:padding="4dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_small"
                        app:shapeAppearanceOverlay="@style/CircleAppearance" />

                    <ImageView
                        android:id="@+id/imgCamera"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="2dp"
                        android:layout_marginBottom="2dp"
                        android:background="@drawable/camera_circle_bg"
                        android:padding="7dp"
                        android:src="@drawable/camera"
                        app:tint="#FFFFFF" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/playfair_display_bold"
                    android:text="Guest User"
                    android:textColor="#163C3C"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="guest@email.com"
                    android:textColor="#777777"
                    android:textSize="15sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- RECENT SEARCHES -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/playfair_display_bold"
                android:text="Recent Searches"
                android:textColor="#163C3C"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvClearRecent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:textColor="#D9A63A"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/recentSearchContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"/>

        </HorizontalScrollView>

        <!-- SAVED PLACES -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginTop="28dp"
            android:fontFamily="@font/playfair_display_bold"
            android:text="Saved Places"
            android:textColor="#163C3C"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- SAVED CARD -->

        <LinearLayout
            android:id="@+id/savedPlacesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
        <!-- LOGOUT -->

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="220dp"
            android:layout_height="55dp"
            android:layout_gravity="center"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="40dp"
            android:backgroundTint="#D9A63A"
            android:text="Logout"
            android:textAllCaps="false"
            android:textColor="#163C3C"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>